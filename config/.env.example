# 小红书 AI Agent 环境配置
# 复制此文件为 .env 并填写配置

# ==================== LLM 配置 ====================

# LLM 提供商: openai, anthropic, zhipu, minimax, kimi, gemini
LLM_PROVIDER=openai

# ========== API Key ==========

# OpenAI
# OPENAI_API_KEY=sk-your-key-here

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# 智谱 GLM
# ZHIPU_API_KEY=your-zhipu-key

# Kimi
# KIMI_API_KEY=your-kimi-key

# Google Gemini
# GEMINI_API_KEY=your-gemini-key

# Minimax
# MINIMAX_API_KEY=your-minimax-key

# ========== Base URL (可选，用于代理) ==========

# OpenAI
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# 智谱 (默认: https://open.bigmodel.cn/api/paas/v4)
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Kimi (默认: https://api.moonshot.cn/v1)
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# Minimax (默认: https://api.minimax.chat/v1)
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Gemini
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1

# ========== 模型 (可选) ==========

# OPENAI_MODEL=gpt-4
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ZHIPU_MODEL=glm-4
# KIMI_MODEL=kimi-flash-1.5
# GEMINI_MODEL=gemini-2.0-flash
# MINIMAX_MODEL=abab6.5s-chat

# ==================== MCP 配置 ====================

# 小红书 MCP 地址
XIAOHONGSHU_MCP_URL=http://localhost:18060/mcp

# ==================== 应用配置 ====================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 数据目录
DATA_DIR=./data

# 日志目录
LOG_DIR=./logs
